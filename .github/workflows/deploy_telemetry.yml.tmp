name: Deploy LangGraph Agent

on:
  push:
    branches:
      - main

env:
  ACR_NAME: ajsagenticacr123
  IMAGE_NAME: langgraph-agent
  RESOURCE_GROUP: ajs-agentic-ai-demo-rg
  WEBAPP_NAME: ajs-agentic-webapp

jobs:
  build-and-deploy:

    runs-on: ubuntu-latest

    steps:

    - name: Checkout code
      uses: actions/checkout@v4


    # Login to Azure
    - name: Login to Azure
      uses: azure/login@v1
      with:
        creds: ${{ secrets.AZURE_CREDENTIALS }}


    # Login to Azure Container Registry
    - name: Login to ACR
      run: |
        az acr login --name $ACR_NAME


    # Create version tag
    - name: Set image tag
      id: version
      run: |
        echo "IMAGE_TAG=v1.0.${{ github.run_number }}" >> $GITHUB_ENV


    # Build Docker Image with version tag
    - name: Build Docker Image
      run: |
        docker build \
        -t $ACR_NAME.azurecr.io/$IMAGE_NAME:$IMAGE_TAG \
        -t $ACR_NAME.azurecr.io/$IMAGE_NAME:latest \
        .


    # Push versioned image
    - name: Push Versioned Image
      run: |
        docker push $ACR_NAME.azurecr.io/$IMAGE_NAME:$IMAGE_TAG


    # Push latest tag
    - name: Push Latest Image
      run: |
        docker push $ACR_NAME.azurecr.io/$IMAGE_NAME:latest

    # Deploy versioned container to Azure App Service
    - name: Deploy to Azure App Service
      run: |
        az webapp config container set \
          --name $WEBAPP_NAME \
          --resource-group $RESOURCE_GROUP \
          --container-image-name $ACR_NAME.azurecr.io/$IMAGE_NAME:$IMAGE_TAG \
          --container-registry-url https://$ACR_NAME.azurecr.io
